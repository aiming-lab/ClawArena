{
  "meta": {
    "lastTouchedVersion": "2026.2.15"
  },
  "models": {
    "providers": {
      "metaclaw-bench": {
        "baseUrl": "${BENCHMARK_BASE_URL}",
        "apiKey": "${BENCHMARK_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "${BENCHMARK_MODEL}",
            "name": "Benchmark model",
            "reasoning": true,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 50000,
            "maxTokens": 50000
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "metaclaw-bench/${BENCHMARK_MODEL}"
      },
      "timeoutSeconds": 6000,
      "compaction": {
        "mode": "safeguard"
      }
    },
