      "proxy",
      "memory",
      "skill"
    ],
    "hook_mode": "proxy",
    "per_scene_isolation": false,
    "upstream_api_base": "${BENCHMARK_BASE_URL}",
    "upstream_api_key": "${BENCHMARK_API_KEY}",
    "upstream_model": "${BENCHMARK_MODEL}",
    "memory_trigger": {
      "every_n_rounds": 0,
      "on_last_round": true
    }
  },
