{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "minItems": 6,
  "maxItems": 6,
  "items": {
    "type": "object",
    "required": ["action_id", "title", "owner", "deadline", "acceptance_criteria"],
    "properties": {
      "action_id": {"type": "string", "pattern": "^RA-0[1-6]$"},
      "title": {"type": "string", "minLength": 3},
      "owner": {"type": "string", "minLength": 1},
      "deadline": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
      "acceptance_criteria": {"type": "string", "minLength": 10}
    }
  }
}
